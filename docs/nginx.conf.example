# Приклад Nginx конфігурації для портфоліо-сайту
# Скопіюйте файл в /etc/nginx/sites-available/portfolio
# і створіть символічне посилання:
#   sudo ln -s /etc/nginx/sites-available/portfolio /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx

server {
    listen 80;
    server_name about.me.hotzagor.tech;

    root /var/www/mysitevizitka;
    index index.html;

    # Основна локація
    location / {
        try_files $uri $uri/ =404;
    }

    # Заборонити доступ до .git, .env та інших прихованих файлів.
    # .well-known залишаємо для Let's Encrypt / Certbot.
    location ~ /\.(?!well-known) {
        deny all;
        return 404;
    }

    location ~* ^/(AGENTS\.md|README\.md|docs/|\.gitignore)$ {
        deny all;
        return 404;
    }

    # Заборонити доступ до службових файлів у будь-якій папці webroot.
    location ~* \.(md|zip|log|env|bak|old)$ {
        deny all;
        return 404;
    }

    # HTML, CSS, JS і Service Worker мають швидко оновлюватися після деплою
    location ~* \.(html|css|js|webmanifest)$ {
        expires -1;
        add_header Cache-Control "no-cache";
        try_files $uri =404;
    }

    # Кеш для версіонованих або рідко змінюваних статичних ресурсів
    location ~* \.(svg|png|ico|woff|woff2)$ {
        expires 30d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # Заголовки безпеки
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    # script-src містить sha256-хеш інлайн-скрипта в <head> (тема/мова без FOUC).
    # Хеш має збігатися з CSP у index.html; онови його, якщо змінюєш інлайн-скрипт.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-fFal+OAm0aZjRiTFKt2h0LSj65vcx3AZvJ3PZbe1MnU=' 'sha256-sIekCaOZp82CLSu5lik6wSADYep4Vw8WNXY9nxL8mp8='; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://about.me.hotzagor.tech; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none';" always;

    # Увімкни після переходу на HTTPS (Certbot):
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml application/xml;
    gzip_min_length 256;
}

# Після отримання HTTPS через Let's Encrypt:
#   sudo apt install certbot python3-certbot-nginx -y
#   sudo certbot --nginx -d about.me.hotzagor.tech
#
# Certbot автоматично додасть SSL-блок і redirect з HTTP на HTTPS.
